# PostgreSQL — obligatoire pour Prisma
# En local : URL de ta machine.
# Sur Railway (backend dans le même projet que Postgres) : référencer la variable DATABASE_URL du service Postgres (hôte *.railway.internal).
# Depuis l’extérieur (Vercel, PC sans VPN) : utiliser l’URL publique Railway (ex. DATABASE_PUBLIC_URL / proxy rlwy.net), pas l’hôte internal.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/marrakech_map?schema=public"

PORT=3000
JWT_SECRET="change-this-in-production"
SEED_ADMIN_ON_BOOT="false"

# Origines CORS autorisées, séparées par des virgules (ex. ton front Vercel)
# FRONTEND_URL="https://ton-app.vercel.app,http://localhost:4200"
