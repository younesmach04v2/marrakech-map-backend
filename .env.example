# PostgreSQL — obligatoire pour Prisma
# En local : URL de ta machine.
# Avec docker compose (dossier backend) : hôte `db` (voir docker-compose.yml).
# Sur Railway (backend dans le même projet que Postgres) : référencer DATABASE_URL du service Postgres (hôte *.railway.internal).
# Depuis l’extérieur (Vercel, PC) : URL publique Railway (ex. DATABASE_PUBLIC_URL / proxy rlwy.net), pas l’hôte internal.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/marrakech_map?schema=public"

PORT=3000
JWT_SECRET="change-this-in-production"
# Par défaut (absent ou != false) : crée l’admin `admin` / mot de passe `admin123` et le workspace « Default map » s’ils manquent. Mettre false pour désactiver.
# SEED_ADMIN_ON_BOOT="false"

# Origines CORS (virgules). Ex. front Railway ou Vercel + local : https://ton-front.up.railway.app,http://localhost:4200,http://127.0.0.1:4200
FRONTEND_URL="http://localhost:4200,http://127.0.0.1:4200"
